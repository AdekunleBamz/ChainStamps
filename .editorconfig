# EditorConfig helps maintain consistent coding styles
root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true
max_line_length = 120

[*.{ts,tsx,js,jsx,json}]
indent_size = 2

[*.{html,css,scss}]
indent_size = 2

[*.{yml,yaml}]
indent_size = 2

[*.clar]
indent_size = 4

[*.md]
trim_trailing_whitespace = false

[*.svg]
indent_size = 2

[Makefile]
indent_style = tab

[*.html]
indent_size = 2

[.env*]
indent_size = 2
