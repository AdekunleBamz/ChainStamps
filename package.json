{
  "name": "chainstamp-tests",
  "version": "1.0.0",
  "description": "Contract and frontend tooling workspace for ChainStamps on Stacks.",
  "type": "module",
  "private": true,
  "scripts": {
    "contracts:check": "clarinet check",
    "check": "npm run contracts:check && npm run test",
    "check:fast": "npm run contracts:check && npm run test:fee",
    "test": "vitest run",
    "test:fee": "vitest run tests/fee-utils.test.ts tests/chainstamp-sdk-fees.test.ts",
    "test:report": "vitest run --coverage --costs",
    "test:ci": "vitest run --coverage --costs",
    "test:watch": "chokidar \"tests/**/*.ts\" \"contracts/**/*.clar\" -c \"npm run test:report\"",
    "consolidate:test-wallets": "node scripts/consolidate-test-wallets.js",
    "frontend:dev": "npm --prefix frontend run dev",
    "frontend:lint": "npm --prefix frontend run lint",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "author": "Adekunle Bamz (@adekunlebamz)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AdekunleBamz/ChainStamps.git"
  },
  "homepage": "https://chainstamp.vercel.app",
  "bugs": {
    "url": "https://github.com/AdekunleBamz/ChainStamps/issues"
  },
  "keywords": [
    "blockchain",
    "stacks",
    "bitcoin",
    "clarity",
    "smart-contracts",
    "document-verification",
    "on-chain-storage"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@stacks/clarinet-sdk": "^3.17.0",
    "@stacks/connect": "^7.10.2",
    "@stacks/transactions": "^7.3.1",
    "@stacks/wallet-sdk": "^7.2.0",
    "@types/node": "^25.6.0",
    "bip39": "^3.1.0",
    "chokidar-cli": "^3.0.0",
    "vitest": "^4.1.5",
    "vitest-environment-clarinet": "^3.0.0"
  }
}
