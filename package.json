{
  "name": "chainstamp-tests",
  "version": "1.0.0",
  "description": "Run unit tests on this project.",
  "type": "module",
  "private": true,
  "scripts": {
    "test": "vitest run",
    "test:fee": "vitest run tests/fee-utils.test.ts",
    "test:report": "vitest run --coverage --costs",
    "test:ci": "vitest run --coverage --costs",
    "test:watch": "chokidar \"tests/**/*.ts\" \"contracts/**/*.clar\" -c \"npm run test:report\"",
    "contracts:check": "clarinet check",
    "frontend:install": "npm --prefix frontend ci",
    "frontend:dev": "npm --prefix frontend run dev",
    "frontend:lint": "npm --prefix frontend run lint",
    "frontend:build": "npm --prefix frontend run build",
    "check:fast": "npm run contracts:check && npm run test:fee"
  },
  "author": "Adekunle Bamz (@adekunlebamz)",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/AdekunleBamz/ChainStamps.git"
  },
  "homepage": "https://chainstamp.vercel.app",
  "bugs": {
    "url": "https://github.com/AdekunleBamz/ChainStamps/issues"
  },
  "keywords": [
    "blockchain",
    "stacks",
    "bitcoin",
    "clarity",
    "smart-contracts",
    "document-verification",
    "on-chain-storage"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@stacks/clarinet-sdk": "^3.9.0",
    "@stacks/connect": "^7.10.2",
    "@stacks/transactions": "^7.3.1",
    "@stacks/wallet-sdk": "^7.2.0",
    "@types/node": "^24.4.0",
    "bip39": "^3.1.0",
    "chokidar-cli": "^3.0.0",
    "vitest": "^4.0.18",
    "vitest-environment-clarinet": "^3.0.0"
  }
}
